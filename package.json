{
  "name": "react-vision-annotator",
  "version": "1.0.0",
  "description": "一个基于 React + Konva.js 的图像标注库，专门为图像标注场景打造。支持矩形/圆形标注、涂鸦/马赛克、撤销重做、缩放旋转等功能。",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "homepage": "https://dingyiweije.github.io/",
  "repository": {
    "type": "git",
    "url": "https://github.com/DingYiWeiJE/react-vision-annotator.git"
  },
  "bugs": {
    "url": "https://github.com/DingYiWeiJE/react-vision-annotator/issues"
  },
  "keywords": [
    "react",
    "annotation",
    "image-annotation",
    "konva",
    "canvas",
    "image-labeling",
    "computer-vision"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "konva": ">=9.0.0",
    "react-konva": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT"
}
